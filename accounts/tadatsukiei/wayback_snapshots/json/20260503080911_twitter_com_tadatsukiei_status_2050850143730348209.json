      {
        "article": {},
        "attachments": {},
        "author_id": "1561753484512612353",
        "conversation_id": "2050506316842414505",
        "created_at": "2026-05-02T09:22:57.000Z",
        "edit_controls": {
          "editable_until": "2026-05-02T10:22:57.000Z",
          "edits_remaining": 5,
          "is_edit_eligible": false
        },
        "edit_history_tweet_ids": [
